generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatar       String?
  isPlus       Boolean  @default(false)
  plusSince    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stays            Stay[]
  userBadges       UserBadge[]
  posts            Post[]
  keycards         Keycard[]
  keycardOffers    KeycardOffer[]
  discussions      Discussion[]
  discussionReplies DiscussionReply[]
  bookingInquiries BookingInquiry[]
}

model HotelGroup {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameZh      String
  logoColor   String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  brands      Brand[]
}

model Alliance {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameZh      String
  description String?
  createdAt   DateTime @default(now())

  brands      BrandAlliance[]
}

model Brand {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameZh      String
  tier        String   @default("luxury")
  groupId     String
  createdAt   DateTime @default(now())

  group       HotelGroup @relation(fields: [groupId], references: [id])
  hotels      Hotel[]
  alliances   BrandAlliance[]
  keycards    Keycard[]
}

model BrandAlliance {
  brandId    String
  allianceId String

  brand      Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  @@id([brandId, allianceId])
}

model Hotel {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameZh      String?
  brandId     String
  city        String
  cityZh      String
  country     String
  countryCode String
  region      String
  latitude    Float
  longitude   Float
  address        String?
  openedYear     Int?
  notes          String?
  websiteUrl     String?
  description    String?
  descriptionZh  String?
  heroImage      String?
  galleryImages  String   @default("[]")
  enrichedAt     DateTime?
  /** Average nightly rate — standard room (CNY) */
  avgBasePrice   Int?
  /** Average nightly rate — suite / villa (CNY) */
  avgSuitePrice  Int?
  priceCurrency  String   @default("CNY")
  /** H&C traveler overall score (0–10) */
  travelerScore         Float?
  travelerRatingCount   Int      @default(0)
  travelerReviewSummary String?
  scoreLocation         Float?
  scoreDesign           Float?
  scoreService          Float?
  scoreDining           Float?
  scoreHardware         Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  brand       Brand    @relation(fields: [brandId], references: [id])
  stays       Stay[]
  posts       Post[]
  keycards    Keycard[]
  bookingInquiries BookingInquiry[]
}

model Stay {
  id            String   @id @default(cuid())
  userId        String
  hotelId       String
  checkIn       DateTime
  checkOut      DateTime
  nights        Int
  roomType      String?
  roomNumber    String?
  notes         String?
  proofUrl      String?
  proofType     String?
  status        String   @default("verified")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  post          Post?
}

model Post {
  id            String   @id @default(cuid())
  userId        String
  hotelId       String
  stayId        String?  @unique
  title         String
  content       String
  images        String   @default("[]")
  upgradeRate   String?
  loungeDining  Int?
  loungeNote    String?
  amenities     Int?
  amenitiesNote String?
  service       Int?
  serviceNote   String?
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  stay          Stay?    @relation(fields: [stayId], references: [id], onDelete: SetNull)
}

model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameZh      String
  description String
  icon        String
  color       String
  category    String
  threshold   Int
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Keycard {
  id          String   @id @default(cuid())
  userId      String
  hotelId     String?
  brandId     String?
  title       String
  description String?
  imageUrl    String
  year        Int?
  tradeType   String   @default("display")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel       Hotel?   @relation(fields: [hotelId], references: [id])
  brand       Brand?   @relation(fields: [brandId], references: [id])
  offers      KeycardOffer[]
}

model KeycardOffer {
  id        String   @id @default(cuid())
  keycardId String
  userId    String
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  keycard   Keycard  @relation(fields: [keycardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Discussion {
  id        String   @id @default(cuid())
  userId    String
  category  String
  groupSlug String?
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies   DiscussionReply[]
}

model DiscussionReply {
  id           String   @id @default(cuid())
  discussionId String
  userId       String
  content      String
  createdAt    DateTime @default(now())

  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BookingInquiry {
  id        String    @id @default(cuid())
  userId    String?
  hotelId   String
  checkIn   DateTime?
  checkOut  DateTime?
  guests    Int       @default(2)
  contact   String?
  source    String    @default("hotel")
  status    String    @default("pending")
  createdAt DateTime  @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  hotel     Hotel     @relation(fields: [hotelId], references: [id])
}