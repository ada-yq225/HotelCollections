                                            <source srcset="/media/tfcbxcek/mahali-mzuri-lion-in-front-of-camp-low-res.jpg?width=640&amp;height=422&amp;quality=70&amp;v=1dc48eeb5e36ff0" media="(max-width: 640px)" />
                                            <img src="/media/tfcbxcek/mahali-mzuri-lion-in-front-of-camp-low-res.jpg?width=640&amp;height=555&amp;quality=70&amp;v=1dc48eeb5e36ff0" alt="" loading="lazy" />
                                        </picture>
</a>
                                </div>

                            <div class="tabbed-listing__item-content cell medium-6 anim--will-fade-up anim--1500" data-animate>
<a href="/mahali-mzuri/"><h2>Mahali Mzuri</h2></a>
<h3>Maasai Mara, Kenya</h3>
<p><span class="NormalTextRun SCXW255755259 BCX0">A luxury, 12-tented safari camp in the </span><span class="NormalTextRun SCXW255755259 BCX0">wider Maasai Mara ecosystem</span><span class="NormalTextRun SCXW255755259 BCX0"> with a front row seat to some of the most spectacular wildlife viewing in Africa, including the Great Migration.</span></p>
                                    <div class="buttons-align-left">
                                        <a class="button" href="/mahali-mzuri/">Read more</a>
                                    </div>
                            </div>
                        </div>
                        <div class="tabbed-listing__item tabbed-listing__item--finch-hattons grid-x">
                                <div class="tabbed-listing__item-image cell medium-6">
