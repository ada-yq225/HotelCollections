{
  "name": "hotel-collection",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "hotels:enrich": "tsx scripts/enrich-hotels.ts",
    "hotels:enrich-images": "tsx scripts/enrich-hotels.ts --images-only",
    "hotels:enrich-all": "node scripts/clean-enrichment-cache.mjs && tsx scripts/enrich-hotels.ts --retry-bad",
    "hotels:scrape-prices": "tsx scripts/scrape-hotel-prices.ts",
    "hotels:scrape-prices-all": "tsx scripts/scrape-hotel-prices.ts --missing-only",
    "hotels:enrich-china-images": "tsx scripts/enrich-china-images.ts",
    "hotels:enrich-all-images": "tsx scripts/enrich-all-images.ts",
    "hotels:clean-cache": "node scripts/clean-enrichment-cache.mjs",
    "logos:manifest": "node scripts/generate-brand-logo-manifest.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.18",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}